# ═══════════════════════════════════════════════════════════════════
# ZamTech Automation Studio — Environment Variables
# Copy to .env.local for local dev. Set on Vercel for production.
# NEVER commit .env.local or real secrets to Git.
# ═══════════════════════════════════════════════════════════════════


# ── Site URLs ─────────────────────────────────────────────────────
# Used in email links, tracking URLs, cookies, and SEO canonical tags.
# TODAY  → https://zamtech.vercel.app
# FUTURE → https://zamtech.co.tz (change both vars at once when domain is live)
NEXT_PUBLIC_SITE_URL=https://zamtech.vercel.app
BETTER_AUTH_URL=https://zamtech.vercel.app


# ── Database (Neon PostgreSQL) ────────────────────────────────────
# Get from: Vercel Dashboard → Integrations → Neon → Connection String
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.neon.tech/neondb?sslmode=require


# ── Auth (Better Auth) ────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=your-random-secret-here


# ── Admin Notifications ───────────────────────────────────────────
# YOUR email — receives every service request, contact message, support ticket.
# Never shown to website visitors.
ADMIN_EMAIL=your-admin-email@example.com


# ── Email Driver ──────────────────────────────────────────────────
# smtp   → Gmail or custom SMTP (use now, no domain needed)
# resend → Resend.com (use in production once zamtech.co.tz domain is verified)
EMAIL_DRIVER=smtp


# ── Resend (production — recommended) ────────────────────────────
# 1. Sign up at https://resend.com
# 2. Go to Domains → Add Domain → add zamtech.co.tz → verify DNS records
# 3. Go to API Keys → Create API Key → paste below
# 4. Change EMAIL_DRIVER=resend above — done. No other changes needed.
#
# FROM addresses that will work automatically once domain is verified:
#   notification@zamtech.co.tz  — new service requests
#   support@zamtech.co.tz       — support tickets
#   noreply@zamtech.co.tz       — tracking confirmations, contact acks
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx


# ── SMTP — Gmail (use now, before domain is ready) ────────────────
# Setup:
#   1. Enable 2-Step Verification on your Google account
#   2. myaccount.google.com → Security → App Passwords
#   3. Create an App Password for "Mail" → use the 16-char code as SMTP_PASS
#
# Note: When using Gmail SMTP, the FROM address (notification@zamtech.co.tz etc.)
# will appear in the email header but Gmail sends it from your Gmail address
# underneath. Switch to Resend for true role-based from addresses.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx



