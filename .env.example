# ─────────────────────────────────────────────────────────────
# ZamTech Automation Studio — Environment Variables Template
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────

# ── Neon PostgreSQL Database ──────────────────────────────────
# Get this from: Vercel → Project → Settings → Environment Variables
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX.neon.tech/neondb?sslmode=require

# ── Better Auth (Admin Login) ─────────────────────────────────
# Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here

# Development URL (change to https://zamtech.vercel.app in production)
BETTER_AUTH_URL=http://localhost:3000

# ── Email Forwarding (francoomichaeldev@gmail.com) ────────────
# Uses Gmail SMTP with an App Password (NOT your regular Gmail password).
# To get App Password: myaccount.google.com → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=francoomichaeldev@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
