# ═══════════════════════════════════════════════════════════════════
# ZamTech Automation Studio — Environment Variables
# Copy to .env.local for local dev. Set on Vercel for production.
# NEVER commit .env.local or real secrets to Git.
# ═══════════════════════════════════════════════════════════════════

# ── Database (Neon PostgreSQL) ────────────────────────────────────
# Get from: Vercel Dashboard → Integrations → Neon
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.neon.tech/neondb?sslmode=require

# ── Auth (Better Auth) ────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-random-64-char-secret-here
# Production URL (change once custom domain is live)
BETTER_AUTH_URL=https://zamtech.vercel.app

# ── Site URL ──────────────────────────────────────────────────────
# Used in tracking emails and WhatsApp message links.
# Change to https://zamtech.co.tz once custom domain is live.
NEXT_PUBLIC_SITE_URL=https://zamtech.vercel.app

# ── Email (SMTP) ──────────────────────────────────────────────────
# Current: Gmail SMTP with an App Password.
# Future:  Swap to Resend (smtp.resend.com) by changing these 4 vars only.
#
# Gmail setup:
#   1. Go to myaccount.google.com → Security → 2-Step Verification → App passwords
#   2. Create app password for "Mail"
#   3. Use the 16-char password (without spaces) as SMTP_PASS
#
# Resend setup (when ready):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxx   (your Resend API key)
#   EMAIL_FROM_ADDRESS=noreply@zamtech.co.tz
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=francoomichaeldev@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Who receives all admin notification emails
ADMIN_EMAIL=francoomichaeldev@gmail.com

# Email "From" display (optional — defaults shown)
EMAIL_FROM_NAME=ZamTech Automation Studio
EMAIL_FROM_ADDRESS=noreply@zamtech.co.tz

# ── WhatsApp Notifications (CallMeBot — Free) ─────────────────────
# Admin receives a WhatsApp message for every form submission.
#
# Setup (one time, 2 minutes):
#   1. Save +34 644 82 17 63 in your contacts as "CallMeBot"
#   2. Send exactly this message to that number on WhatsApp:
#      I allow callmebot to send me messages
#   3. You will receive your API key back within seconds
#   4. Paste it below
#
# Reference: https://www.callmebot.com/blog/free-api-whatsapp-messages/
ADMIN_WHATSAPP_PHONE=255796985138
CALLMEBOT_API_KEY=your-callmebot-api-key-here
